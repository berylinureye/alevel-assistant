# Copy this file to .env and fill in ANTHROPIC_API_KEY for Viviai/New API.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.viviai.cc

# Direct provider keys are optional; leave empty when using Viviai.
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# Model defaults used by router/models.py and grader/multi_agent_config.py.
BASE_MODEL=gemini-3-flash-preview
REVIEW_MODEL=gemini-3-pro-preview
EXPLAIN_MODEL=gemini-2.5-flash-thinking
VIVIAI_FAST_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-3-flash-preview
VIVIAI_ACCURATE_MODELS=gemini-2.5-pro,gemini-3-pro-preview

# Empty means vision reuses BASE_MODEL.
VISION_MODEL=
# Optional OCR model ID for DashScope or VIVIAI/Gemini when Mathpix is not configured.
OCR_MODEL=

# Optional Mathpix Convert API OCR. When both values are set, OCR uses Mathpix first.
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
MATHPIX_BASE_URL=https://api.mathpix.com
MATHPIX_TIMEOUT_SECONDS=15

# OCR cooperation guardrails. Mathpix/local OCR is collected in parallel; only OCR
# text that appears to contain question-language is used as a prompt hint.
SEGMENT_OCR_HINT_ENABLED=1
SEGMENT_OCR_HINT_TIMEOUT_SECONDS=8
SEGMENT_OCR_HINT_CHARS=6000
SEGMENT_OCR_HINT_REQUIRE_QUESTION_TEXT=1

# Optional local Python OCR fallback for page-header detection and weak text probes.
# Requires a system tesseract binary, e.g. `brew install tesseract` on macOS.
LOCAL_OCR_ENABLED=0
LOCAL_OCR_PROVIDER=tesseract
LOCAL_OCR_LANG=eng
LOCAL_OCR_TIMEOUT_SECONDS=3
IMAGE_OSD_ENABLED=0
IMAGE_OSD_TIMEOUT_SECONDS=1.5

# 10-image fast-batch budget knobs.
FAST_BATCH_RECOGNITION_TIMEOUT_SECONDS=18
FAST_BATCH_PREPARE_TIMEOUT_SECONDS=18
FAST_BATCH_PREPARE_MAX_WORKERS=10
FAST_BATCH_QUESTION_TIMEOUT_SECONDS=32
FAST_BATCH_MAX_WORKERS=16
FAST_BATCH_PARSE_ATTEMPTS=1
FAST_BATCH_REQUEST_RETRIES=0

# Optional MinerU runtime for question-bank PDF parsing.
# MinerU requires Python 3.10-3.13; install it in an isolated env:
#   uv venv --python /Library/Frameworks/Python.framework/Versions/3.10/bin/python3.10 .venv-mineru
#   uv pip install --python .venv-mineru/bin/python -r requirements-mineru.txt
MINERU_BIN=.venv-mineru/bin/mineru
MINERU_OUTPUT_DIR=data/mineru_output
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=1200
# Apple Silicon: set to 1 if the main Python runs under Rosetta/x86_64.
MINERU_FORCE_ARM64=
QUESTIONBANK_USE_MINERU=0
QUESTIONBANK_REQUIRE_MINERU=0
