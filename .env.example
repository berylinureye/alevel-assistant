# Copy this file to .env and fill in ANTHROPIC_API_KEY for Viviai/New API.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.viviai.cc

# Direct provider keys are optional; leave empty when using Viviai.
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# Model defaults used by router/models.py and grader/multi_agent_config.py.
BASE_MODEL=gemini-3-flash-preview
REVIEW_MODEL=gemini-3-pro-preview
EXPLAIN_MODEL=gemini-2.5-flash-thinking
VIVIAI_FAST_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-3-flash-preview
VIVIAI_ACCURATE_MODELS=gemini-2.5-pro,gemini-3-pro-preview

# Empty means vision reuses BASE_MODEL.
VISION_MODEL=
OCR_MODEL=

# Optional MinerU runtime for question-bank PDF parsing.
# MinerU requires Python 3.10-3.13; install it in an isolated env:
#   uv venv --python /Library/Frameworks/Python.framework/Versions/3.10/bin/python3.10 .venv-mineru
#   uv pip install --python .venv-mineru/bin/python -r requirements-mineru.txt
MINERU_BIN=.venv-mineru/bin/mineru
MINERU_OUTPUT_DIR=data/mineru_output
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=1200
# Apple Silicon: set to 1 if the main Python runs under Rosetta/x86_64.
MINERU_FORCE_ARM64=
QUESTIONBANK_USE_MINERU=0
QUESTIONBANK_REQUIRE_MINERU=0
